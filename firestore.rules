rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasActiveProfile() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && userProfile().data.active == true
        && userProfile().data.role in ['ADMIN', 'COMERCIAL'];
    }

    function isAdmin() {
      return hasActiveProfile() && userProfile().data.role == 'ADMIN';
    }

    function isCommercial() {
      return hasActiveProfile() && userProfile().data.role == 'COMERCIAL';
    }

    function isOwnUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isInitialAdminBootstrap(userId) {
      return isOwnUser(userId)
        && request.auth.token.email == 'nuria.queraltt@gmail.com'
        && request.resource.data.role == 'ADMIN'
        && request.resource.data.active == true;
    }

    match /users/{userId} {
      allow read: if isOwnUser(userId) || isAdmin();
      allow create: if isAdmin() || isInitialAdminBootstrap(userId);
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /leads/{leadId} {
      allow read, create, update: if hasActiveProfile();
      allow delete: if false;
    }

    match /activities/{activityId} {
      allow read, create: if hasActiveProfile();
      allow update, delete: if false;
    }

    match /tasks/{taskId} {
      allow read, create, update: if hasActiveProfile();
      allow delete: if false;
    }

    match /trips/{tripId} {
      allow read: if hasActiveProfile();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /notifications/{notificationId} {
      allow read, create, update: if hasActiveProfile();
      allow delete: if false;
    }

    match /ai_suggestions/{suggestionId} {
      allow read, create, update: if isAdmin();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
